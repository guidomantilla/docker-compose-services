# ------------- SERVICES BULK ------------- #
_SERVICES_UP_LIST=(
  # AIRFLOW
  # CLICKHOUSE
  # GCP_PUBSUB
  # KEYCLOAK
  # LOCALSTACK
  # MAILHOG
  # METABASE
  # MONGO
  # N8N
  # NEO4J
  # OPENFGA
  # ORACLE
  # PINOT
  # POSTGRES
  # RABBITMQ
  # REDIS
  # REDPANDA
  # SONARQUBE
  # SQLSERVER
  # SUPABASE
  # SUPERSET
  # TELEMETRY
  # TEMPORAL
  # TIMESCALEDB
  # VERSITYGW
)
alias  services-up='for s in ${_SERVICES_UP_LIST[@]}; do eval "${s}_STACK_UP"; done'
alias  services-stop='for s in ${_SERVICES_UP_LIST[@]}; do eval "${s}_STACK_STOP"; done'
alias  services-down='for s in ${_SERVICES_UP_LIST[@]}; do eval "${s}_STACK_DOWN"; done'
