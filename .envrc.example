# --- services ---
export SERVICES_HOME="$HOME/Workspace/services"

export AWS_ACCESS_KEY_ID="test"
export AWS_SECRET_ACCESS_KEY="test"
export AWS_DEFAULT_REGION="us-east-1"
export PAT=""

# ------------- AIRFLOW ------------- #
alias  AIRFLOW_STACK_UP="docker compose -f $SERVICES_HOME/airflow/airflow-stack-compose.yml -p airflow-stack up --detach --remove-orphans"
alias  AIRFLOW_STACK_STOP="docker compose -f $SERVICES_HOME/airflow/airflow-stack-compose.yml -p airflow-stack stop"
alias  AIRFLOW_STACK_DOWN="docker compose -f $SERVICES_HOME/airflow/airflow-stack-compose.yml -p airflow-stack down"
export AIRFLOW_HOME="$SERVICES_HOME/airflow"
export AIRFLOW_VOLUME_DIR="$AIRFLOW_HOME/volume"

# ------------- CLICKHOUSE ------------- #
alias  CLICKHOUSE_STACK_UP="docker compose -f $SERVICES_HOME/clickhouse/clickhouse-stack-compose.yml -p clickhouse-stack up --detach --remove-orphans"
alias  CLICKHOUSE_STACK_STOP="docker compose -f $SERVICES_HOME/clickhouse/clickhouse-stack-compose.yml -p clickhouse-stack stop"
alias  CLICKHOUSE_STACK_DOWN="docker compose -f $SERVICES_HOME/clickhouse/clickhouse-stack-compose.yml -p clickhouse-stack down"
export CLICKHOUSE_PASSWORD=""  # Set your password
export CLICKHOUSE_VOLUME_DIR="$SERVICES_HOME/clickhouse/volume"

# ------------- GCP PUBSUB ------------- #
alias  GCP_PUBSUB_STACK_UP="docker compose -f $SERVICES_HOME/gcp-pubsub/gcp-pubsub-stack-compose.yml -p gcp-pubsub-stack up --detach --remove-orphans"
alias  GCP_PUBSUB_STACK_STOP="docker compose -f $SERVICES_HOME/gcp-pubsub/gcp-pubsub-stack-compose.yml -p gcp-pubsub-stack stop"
alias  GCP_PUBSUB_STACK_DOWN="docker compose -f $SERVICES_HOME/gcp-pubsub/gcp-pubsub-stack-compose.yml -p gcp-pubsub-stack down"
export PUBSUB_EMULATOR_HOST="localhost:8085"

# ------------- KEYCLOAK ------------- #
alias  KEYCLOAK_STACK_UP="docker compose -f $SERVICES_HOME/keycloak/keycloak-stack-compose.yml -p keycloak-stack up --detach --remove-orphans"
alias  KEYCLOAK_STACK_STOP="docker compose -f $SERVICES_HOME/keycloak/keycloak-stack-compose.yml -p keycloak-stack stop"
alias  KEYCLOAK_STACK_DOWN="docker compose -f $SERVICES_HOME/keycloak/keycloak-stack-compose.yml -p keycloak-stack down"
export KEYCLOAK_ADMIN_USERNAME="keycloak"
export KEYCLOAK_ADMIN_PASSWORD=""  # Set your password
export KEYCLOAK_VOLUME_DIR="$SERVICES_HOME/keycloak/volume"

# ------------- LOCALSTACK ------------- #
alias  LOCALSTACK_STACK_UP="docker compose -f $SERVICES_HOME/localstack-pro/localstack-pro-stack-compose.yml -p localstack-pro-stack up --detach --remove-orphans"
alias  LOCALSTACK_STACK_STOP="docker compose -f $SERVICES_HOME/localstack-pro/localstack-pro-stack-compose.yml -p localstack-pro-stack stop"
alias  LOCALSTACK_STACK_DOWN="docker compose -f $SERVICES_HOME/localstack-pro/localstack-pro-stack-compose.yml -p localstack-pro-stack down"
export LOCALSTACK_AUTH_TOKEN=""  # Get from https://app.localstack.cloud
export LOCALSTACK_DOCKER_NAME="localstack-pro"
export LOCALSTACK_VOLUME_DIR="$SERVICES_HOME/localstack-pro/volume"

